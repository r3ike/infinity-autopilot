menuconfig BMI088_DRIVER_ENABLED
    bool "Supporto BMI088 driver"
    default y



if BMI088_DRIVER_ENABLED

config BMI088_NUM_INSTANCES
    int "Numero di sensori BMI088"
    range 1 3
    default 1

menu "BMI088 LPF settings"

config BMI088_ACCEL_LPF
    int "Accelerometer LPF cutoff frequency (Hz)"
    range 0 1000
    default 80

config BMI088_GYRO_LPF
    int "Gyroscope LPF cutoff frequency (Hz)"
    range 0 1000
    default 200

endmenu



endif # ENABLE_BMI088
