menuconfig BN280_DRIVER_ENABLED
    bool "Supporto BN280 driver"



if BN280_DRIVER_ENABLED

config BN280_NUM_INSTANCES
    int "Numero di GPS BN280 presenti sulla board"
    range 1 3
    default 1
    help
      Specifica quante istanze di GPS BN280 sono presenti sulla board.

#Instanza 0
choice
    prompt "BN280 0 Serial interface"
    default BN280_0_SERIAL1
    depends on BN280_DRIVER_ENABLED && BN280_NUM_INSTANCES >= 1

config BN280_0_SERIAL1
    bool Serial1

config BN280_0_SERIAL2
    bool Serial2
endchoice


#Instanza 1
choice
    prompt "BN280 1 Serial interface"
    default BN280_1_SERIAL1
    depends on BN280_DRIVER_ENABLED && BN280_NUM_INSTANCES >= 2

config BN280_1_SERIAL1
    bool Serial1

config BN280_1_SERIAL2
    bool Serial2
endchoice


#Instanza 2
choice
    prompt "BN280 2 Serial interface"
    default BN280_2_SERIAL1
    depends on BN280_DRIVER_ENABLED && BN280_NUM_INSTANCES >= 3

config BN280_2_SERIAL1
    bool Serial1

config BN280_2_SERIAL2
    bool Serial2
endchoice


endif