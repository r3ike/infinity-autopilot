# CONFIG_TARGET_SITL is not set
CONFIG_TARGET_TEENSY41=y

#
# HAL Configuration
#

#
# GPS Drivers
#
CONFIG_BN280_DRIVER_ENABLED=y
CONFIG_BN280_NUM_INSTANCES=2
CONFIG_BN280_0_SERIAL=0
CONFIG_BN280_1_SERIAL=1
# end of GPS Drivers

#
# IMU Drivers
#
CONFIG_BMI088_DRIVER_ENABLED=y
CONFIG_BMI088_NUM_INSTANCES=2
CONFIG_BMI088_0_I2C=y
# CONFIG_BMI088_0_SPI is not set
CONFIG_BMI088_0_I2C_ADDR=0x68
# CONFIG_BMI088_1_I2C is not set
CONFIG_BMI088_1_SPI=y
CONFIG_BMI088_1_SPI_CS=11
# CONFIG_ICM42688P_DRIVER_ENABLED is not set
# end of IMU Drivers
# end of HAL Configuration

#
# Modules Configuration
#

#
# Logger module configuration
#
CONFIG_LOGGER_ENABLED=y
CONFIG_LOG_IMU_ENABLED=y
CONFIG_LOG_GPS_ENABLED=y
CONFIG_LOG_MAG_ENABLED=y
CONFIG_LOG_BARO_ENABLED=y
CONFIG_LOG_LIDAR_ENABLED=y
# CONFIG_LOG_EKF_ENABLED is not set
CONFIG_LOG_SYS_INFO_ENABLED=y
CONFIG_LOGGER_BUFFER_SIZE=32
# end of Logger module configuration
# end of Modules Configuration
