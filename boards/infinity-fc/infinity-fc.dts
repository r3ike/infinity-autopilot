/dts-v1/;

/* Inclusione del file base del microcontrollore STM32H753ZI */
#include <st/h7/stm32h753Xi.dtsi>

/* Inclusione degli header per le macro utili */
#include <dt-bindings/pinctrl/stm32-pinctrl.h>
#include <dt-bindings/clock/stm32h7_clock.h>
#include <dt-bindings/gpio/gpio.h>

/ {
    model = "Infinity Flight Computer";
    compatible = "infinity-autopilot,flight-controller";

    /* 1. Definizione degli Oscillatori Esterni (HSE e LSE) */
    clocks {
        /* Oscillatore ad alta velocità (HSE) a 25 MHz */
        clk_hse: clk-hse {
            #clock-cells = <0>;
            compatible = "fixed-clock";
            clock-frequency = <25000000>; /* 25 MHz */
            status = "okay";
        };

        /* Oscillatore a bassa velocità (LSE) per l'RTC a 32.768 kHz */
        clk_lse: clk-lse {
            #clock-cells = <0>;
            compatible = "fixed-clock";
            clock-frequency = <32768>;
            status = "okay";
        };
    };

    /* (Opzionale) Nodo per alias, utile per riferimenti veloci nel codice */
    aliases {
        led0 = &green_led;
    };

    /* Definizione di LED o altri componenti custom sulla scheda */
    leds {
        compatible = "gpio-leds";
        green_led: led_0 {
            gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>;
            label = "User LED";
        };
    };

    /* Lo spazio `chosen` permette di selezionare la console di debug */
    chosen {
        zephyr,console = &usart1; /* Usa USART1 per output di log */
        zephyr,shell-uart = &usart1;
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
    };
};

/* 2. Configurazione del Clock Tree */
&rcc {
    clocks = <&pll>; /* Il PLL è la sorgente di clock del sistema */
    clock-frequency = <DT_FREQ_M(480)>; /* Frequenza massima del core a 480 MHz */

    /* Prescaler per i vari domini di clock (configurazione standard) */
    d1cpre = <1>;  /* Prescaler per il dominio D1 (CPU core) */
    hpre = <2>;    /* Prescaler per il bus AHB (HCLK = SYSCLK / 2 = 240 MHz) */
    d1ppre = <2>;  /* Prescaler per APB3 (PCLK3) */
    d2ppre1 = <2>; /* Prescaler per APB1 */
    d2ppre2 = <2>; /* Prescaler per APB2 */
    d3ppre = <2>;  /* Prescaler per APB4 */

    /* Attivazione degli oscillatori esterni */
    pll: pll {
        compatible = "st,stm32h7-pll-clock";
        status = "okay";

        /* Sorgente del PLL: l'oscillatore HSE */
        clocks = <&clk_hse>;

        /* Configurazione per ottenere 480 MHz da un HSE a 25 MHz */
        /* (I valori possono variare in base alla configurazione esatta) */
        div-m = <5>;      /* M = 5 */
        mul-n = <192>;    /* N = 192 */
        div-p = <2>;      /* P = 2 */
        div-q = <20>;     /* Q = 20 */
        div-r = <2>;      /* R = 2 */
    };
};

/* 3. Attivazione e Configurazione delle Periferiche */

/* --- SPI1 (PA4=NSS, PA5=SCK, PA6=MISO, PA7=MOSI) --- */
&spi1 {
    pinctrl-0 = <&spi1_nss_pa4 &spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
    pinctrl-names = "default";
    cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>; /* NSS manuale via GPIO */
    status = "okay";

    /* Esempio di dispositivo SPI connesso */
    my_spi_device: device@0 {
        compatible = "some-spi-device";
        reg = <0>;
        spi-max-frequency = <10000000>;
    };
};

/* --- SPI2 (PB12=NSS, PB13=SCK, PB14=MISO, PB15=MOSI) --- */
&spi2 {
    pinctrl-0 = <&spi2_nss_pb12 &spi2_sck_pb13 &spi2_miso_pb14 &spi2_mosi_pb15>;
    pinctrl-names = "default";
    cs-gpios = <&gpiob 12 GPIO_ACTIVE_LOW>; /* NSS manuale */
    status = "okay";
};

/* --- I2C1 (PB8=SCL, PB9=SDA) --- */
&i2c1 {
    pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
    pinctrl-names = "default";
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>; /* 400 kHz */
};

/* --- I2C2 (PB10=SCL, PB11=SDA) --- */
&i2c2 {
    pinctrl-0 = <&i2c2_scl_pb10 &i2c2_sda_pb11>;
    pinctrl-names = "default";
    status = "okay";
    clock-frequency = <I2C_BITRATE_FAST>;
};

/* --- UART1 (PA0=TX, PA1=RX) --- */
&uart1 {
    pinctrl-0 = <&uart1_tx_pa0 &uart1_rx_pa1>;
    pinctrl-names = "default";
    status = "okay";
    current-speed = <115200>;
};

/* --- USART1 (PA9=TX, PA10=RX) --- */
&usart1 {
    pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
    pinctrl-names = "default";
    status = "okay";
    current-speed = <115200>;
};

/* --- TIM1 per PWM (PA8=CH1, PA9=CH2, PA10=CH3, PA11=CH4) --- */
&timers1 {
    status = "okay";
    pwm: pwm {
        pinctrl-0 = <&tim1_ch1_pwm_pa8 &tim1_ch2_pwm_pa9 &tim1_ch3_pwm_pa10 &tim1_ch4_pwm_pa11>;
        pinctrl-names = "default";
        status = "okay";
        st,prescaler = <10000>; /* Esempio: regola per la frequenza PWM desiderata */
    };
};